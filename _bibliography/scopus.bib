doi={10.1109/ETFA.2012.6489553},
art_number={6489553},
note={Conference of 2012 IEEE 17th International Conference on Emerging Technologies and Factory Automation, ETFA 2012 ; Conference Date: 17 September 2012 Through 21 September 2012;  Conference Code:96594},
