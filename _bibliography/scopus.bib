@ARTICLE{Tramarin2015841,
author={Tramarin, F. and Vitturi, S.},
title={Strategies and services for energy efficiency in real-time ethernet networks},
journal={IEEE Transactions on Industrial Informatics},
year={2015},
volume={11},
number={3},
pages={841-852},
