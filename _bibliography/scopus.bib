@CONFERENCE{Seno2012,
author={Seno, L. and Vitturi, S. and Tramarin, F.},
title={Tuning of IEEE 802.11 MAC for improving real-time in industrial wireless networks},
journal={IEEE International Conference on Emerging Technologies and Factory Automation, ETFA},
